#############################################
# AcestarAI local development environment
# Copy this file to `.env` and fill in values
#############################################

############################
# Required app configuration
############################
PORT=8787
APP_URL=http://localhost:8787
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d
SCHEDULER_SECRET=replace_with_a_long_random_scheduler_secret
MORNING_REMINDER_HOUR=8
END_OF_DAY_DIGEST_HOUR=18

############################
# Required Supabase settings
############################
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

############################
# AI providers
# OpenAI is the main provider for transcription, summaries, and Ask Acestar
############################
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o
OPENAI_RAG_MODEL=gpt-5.2-chat-latest
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

############################
# Optional AI fallbacks
############################
OPENROUTER_API_KEY=
OPENROUTER_TRANSCRIBE_MODEL=openai/whisper-large-v3-turbo
OPENROUTER_SUMMARY_MODEL=meta-llama/llama-3.1-8b-instruct:free

ASSEMBLYAI_API_KEY=

############################
# Optional local diarization service
############################
DIARIZATION_URL=http://localhost:5000

############################
# File and storage limits
############################
STORAGE_LIMIT_MB=50
MAX_UPLOAD_FILE_SIZE_MB=500

############################
# Local recording device defaults
# Adjust these to match your Mac audio device names if you use local recording
############################
DEVICE=BlackHole 2ch
MIC=MacBook Pro Microphone

############################
# Email delivery
# If omitted, verification/reset emails will log to the server console
############################
EMAIL_FROM=noreply@acestarai.com
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

############################
# Optional Google sign-in
# For local testing, add http://localhost:8787/api/auth/google/callback
# as an authorized redirect URI in Google Cloud Console
############################
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/auth/google/callback

############################
# Optional Microsoft calendar connection
############################
MICROSOFT_TENANT_ID=organizations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:8787/api/microsoft/callback
