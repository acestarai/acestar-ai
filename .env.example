PORT=8787
DEVICE=BlackHole 2ch
MIC=MacBook Air Microphone

# OpenAI Configuration (Optional - for paid models)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Watson Speech to Text Configuration (Optional - for Watson STT)
WATSON_STT_API_KEY=your_watson_stt_api_key_here
WATSON_STT_URL=https://api.us-south.speech-to-text.watson.cloud.ibm.com

# WatsonX.AI Configuration (Optional - for WatsonX summarization)
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
